<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<script>
document.addEventListener('DOMContentLoaded', function() {

  // ==========================
  // TABS SEMANAL: RUTAS / INDIVIDUALES
  // ==========================
  const btnRutasSem   = document.getElementById('btn-tab-semanal-rutas');
  const btnIndSem     = document.getElementById('btn-tab-semanal-individuales');
  const panelRutasSem = document.getElementById('panel-semanal-rutas');
  const panelIndSem   = document.getElementById('panel-semanal-individuales');

  function activarTabSemanal(tab) {
    if (!btnRutasSem || !btnIndSem || !panelRutasSem || !panelIndSem) return;

    const isRutas = tab === 'rutas';

    panelRutasSem.classList.toggle('hidden', !isRutas);
    panelIndSem.classList.toggle('hidden', isRutas);

    btnRutasSem.classList.toggle('bg-blue-50', isRutas);
    btnRutasSem.classList.toggle('text-blue-600', isRutas);
    btnRutasSem.classList.toggle('border-blue-500', isRutas);

    btnIndSem.classList.toggle('bg-blue-50', !isRutas);
    btnIndSem.classList.toggle('text-blue-600', !isRutas);
    btnIndSem.classList.toggle('border-blue-500', !isRutas);
  }

  btnRutasSem?.addEventListener('click', () => activarTabSemanal('rutas'));
  btnIndSem?.addEventListener('click', () => activarTabSemanal('individuales'));
  activarTabSemanal('rutas');


  // ==========================
  // Selector ruta -> botón "Ver detalle"
  // ==========================
  const selRuta = document.getElementById('filtro-ruta-tabla-semanal');
  const btnDetalle = document.getElementById('btn-detalle-ruta-semanal');

  function filtrarRutasUI(rutaId) {
    // desktop rows
    document.querySelectorAll('[data-ruta-row="1"]').forEach(row => {
      const id = row.getAttribute('data-ruta-id');
      row.classList.toggle('hidden', (rutaId !== 'all' && rutaId !== id));
    });

    // móvil cards
    document.querySelectorAll('[data-ruta-card="1"]').forEach(card => {
      const id = card.getAttribute('data-ruta-id');
      card.classList.toggle('hidden', (rutaId !== 'all' && rutaId !== id));
    });

    // totales: solo cuando "all"
    document.querySelectorAll('[data-totales-row="1"]').forEach(tr => {
      tr.classList.toggle('hidden', rutaId !== 'all');
    });
  }

  if (selRuta && btnDetalle) {
    selRuta.addEventListener('change', function () {
      const val = this.value || 'all';
      btnDetalle.disabled = (val === 'all');
      filtrarRutasUI(val);
    });

    btnDetalle.addEventListener('click', function () {
      const rutaId = selRuta.value;
      if (!rutaId || rutaId === 'all') return;

      // intenta click del botón de fila (desktop/móvil)
      const rowBtn = document.querySelector(`[data-open-ruta-detalle="semanal"][data-ruta-id="${rutaId}"]`);
      if (rowBtn) rowBtn.click();
    });

    // estado inicial
    filtrarRutasUI(selRuta.value || 'all');
  }


  // =======================
  // CHART HELPERS (evitar duplicados)
  // =======================
  function renderBarChart(canvas, labels, data) {
    if (!canvas || typeof Chart === 'undefined') return;
    try {
      if (canvas._chart) canvas._chart.destroy();
      canvas._chart = new Chart(canvas, {
        type: 'bar',
        data: { labels, datasets: [{ data, borderRadius: 8, maxBarThickness: 44 }] },
        options: { responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false} } }
      });
    } catch (e) {}
  }

  function renderLineChart(canvas, labels, data) {
    if (!canvas || typeof Chart === 'undefined') return;
    try {
      if (canvas._chart) canvas._chart.destroy();
      canvas._chart = new Chart(canvas, {
        type: 'line',
        data: { labels, datasets: [{ data, tension: 0.35, fill: false }] },
        options: { responsive:true, maintainAspectRatio:false, plugins:{ legend:{display:false} } }
      });
    } catch (e) {}
  }

  // =======================
  // GRÁFICAS RUTAS
  // =======================
  const canvasRutasSemana    = document.getElementById('chart-rutas-semana');
  const canvasRutasSemanaDia = document.getElementById('chart-rutas-semana-dia');

  if (canvasRutasSemana) {
    const labelsRuta = JSON.parse(canvasRutasSemana.dataset.labels || '[]');
    const montosRuta = JSON.parse(canvasRutasSemana.dataset.montos || '[]');
    if (labelsRuta.length && montosRuta.length) renderBarChart(canvasRutasSemana, labelsRuta, montosRuta);
  }

  if (canvasRutasSemanaDia) {
    const labelsDia = JSON.parse(canvasRutasSemanaDia.dataset.labels || '[]');
    const montosDia = JSON.parse(canvasRutasSemanaDia.dataset.montos || '[]');
    if (labelsDia.length && montosDia.length) renderBarChart(canvasRutasSemanaDia, labelsDia, montosDia);
  }

  const btnChartRutasRuta  = document.getElementById('btn-chart-rutas-por-ruta');
  const btnChartRutasDia   = document.getElementById('btn-chart-rutas-por-dia');
  const cardChartRutasRuta = document.getElementById('card-chart-rutas-ruta');
  const cardChartRutasDia  = document.getElementById('card-chart-rutas-dia');

  function activarChartRutas(tipo) {
    if (!cardChartRutasRuta || !cardChartRutasDia) return;
    const isRuta = tipo === 'ruta';

    cardChartRutasRuta.classList.toggle('hidden', !isRuta);
    cardChartRutasDia.classList.toggle('hidden', isRuta);

    btnChartRutasRuta?.classList.toggle('bg-blue-50', isRuta);
    btnChartRutasRuta?.classList.toggle('text-blue-600', isRuta);
    btnChartRutasRuta?.classList.toggle('border-blue-500', isRuta);

    btnChartRutasDia?.classList.toggle('bg-blue-50', !isRuta);
    btnChartRutasDia?.classList.toggle('text-blue-600', !isRuta);
    btnChartRutasDia?.classList.toggle('border-blue-500', !isRuta);
  }

  btnChartRutasRuta?.addEventListener('click', () => activarChartRutas('ruta'));
  btnChartRutasDia?.addEventListener('click', () => activarChartRutas('dia'));
  activarChartRutas('ruta');


  // =======================
  // GRÁFICA INDIVIDUALES (por día)
  // =======================
  const canvasVentasDia = document.getElementById('chart-ventas-semana-dia');
  if (canvasVentasDia) {
    const labels = JSON.parse(canvasVentasDia.dataset.labels || '[]');
    const data   = JSON.parse(canvasVentasDia.dataset.montos || '[]');
    if (labels.length && data.length) renderLineChart(canvasVentasDia, labels, data);
  }


  // =======================
  // ✅ FLATPICKR: SEMANA JUEVES -> MIÉRCOLES (NO QUITAR)
  // =======================
  const START_DAY = 4; // Jueves

  function getStartOfCustomWeek(date) {
    const d = new Date(date);
    const day = d.getDay();
    const diff = (day - START_DAY + 7) % 7;
    d.setDate(d.getDate() - diff);
    d.setHours(0,0,0,0);
    return d;
  }

  // ISO week number (para que coincida con Carbon->week del jueves)
  function getISOWeekYear(date) {
    const d = new Date(Date.UTC(date.getFullYear(), date.getMonth(), date.getDate()));
    const dayNum = d.getUTCDay() || 7;      // 1..7
    d.setUTCDate(d.getUTCDate() + 4 - dayNum);
    const yearStart = new Date(Date.UTC(d.getUTCFullYear(), 0, 1));
    const weekNo = Math.ceil((((d - yearStart) / 86400000) + 1) / 7);
    return { week: weekNo, year: d.getUTCFullYear() };
  }

  function formatYMD(date) {
    const y = date.getFullYear();
    const m = String(date.getMonth() + 1).padStart(2, '0');
    const d = String(date.getDate()).padStart(2, '0');
    return `${y}-${m}-${d}`;
  }

  function updateSemanaLabel(fp, anyDate) {
    const start = getStartOfCustomWeek(anyDate);
    const info = getISOWeekYear(start);
    fp.input.value = `Semana ${info.week}, ${info.year}`;
  }

  if (typeof flatpickr !== 'undefined') {
    flatpickr("#semana_selector", {
      locale: { ...flatpickr.l10ns.es, firstDayOfWeek: START_DAY },
      weekNumbers: true,
      defaultDate: "{{ $fechaInicio->format('Y-m-d') }}",
      plugins: (typeof weekSelectPlugin !== 'undefined')
        ? [ new weekSelectPlugin({ weekNumbers: true }) ]
        : [],

      onReady(selectedDates, dateStr, instance) {
        const baseDate = selectedDates?.[0] || new Date("{{ $fechaInicio->format('Y-m-d') }}");
        updateSemanaLabel(instance, baseDate);
      },

      onChange(selectedDates, dateStr, instance) {
        if (!selectedDates.length) return;

        const start = getStartOfCustomWeek(selectedDates[0]);
        updateSemanaLabel(instance, start);

        const fechaInicio = formatYMD(start);

        const url = new URL(window.location.href);
        url.searchParams.set('fecha', fechaInicio);
        url.searchParams.set('tipo', 'semanal');

        const sucursalSelect = document.getElementById('sucursal_id');
        if (sucursalSelect && sucursalSelect.value) url.searchParams.set('sucursal_id', sucursalSelect.value);

        window.location.href = url.toString();
      }
    });
  }

});
</script>
