use Carbon\Carbon;

$scope = 'semanal';

// Si viene como $datos['semanal'], lo aplanamos
if (isset($datos['semanal'])) {
    $datos = $datos['semanal'];
}
$datos = $datos ?? []; // ✅ importante

// ✅ Misma lógica que controlador (jueves a miércoles)
$fechaInicio  = Carbon::parse($fecha);
$fechaFin     = $fechaInicio->copy()->addDays(6);
$semanaNumero = $fechaInicio->week;
$anio         = $fechaInicio->year;

// =======================
// RUTAS SEMANALES
// =======================
$rutasSemPorEmpleado = collect(data_get($datos, 'rutas_semanales.por_empleado', []));
$rutasPorDia         = collect(data_get($datos, 'rutas_semanales.por_dia', []));

$estadRutas       = data_get($datos, 'rutas_semanales.estadisticas', null);
$totalRutasSemana = (int)($estadRutas->total_rutas ?? $rutasSemPorEmpleado->count());

// Totales de rutas
$totalVentasRutas  = 0;
$totalGastosRutas  = 0;
$totalBalanceRutas = 0;

// ✅ DEVOLUCIONES
$totalDevProdUnid  = 0;
$totalDevProdMonto = 0;
$totalDevEfectivo  = 0;

foreach ($rutasSemPorEmpleado as $ruta) {
    $ventasMonto = (float)($ruta->total_ventas_monto ?? 0);
    $gastosMonto = (float)($ruta->gastos_ruta ?? 0);

    $totalVentasRutas  += $ventasMonto;
    $totalGastosRutas  += $gastosMonto;
    $totalBalanceRutas += ($ventasMonto - $gastosMonto);

    $totalDevProdUnid  += (int)($ruta->total_devoluciones ?? 0);
    $totalDevProdMonto += (float)($ruta->total_devoluciones_monto ?? 0);

    // ✅ soporta ambos nombres (igual que diario)
    $totalDevEfectivo  += (float)($ruta->devoluciones_efectivo_monto ?? $ruta->devoluciones_efectivo ?? 0);
}

$totalDevTotal = (float)$totalDevProdMonto + (float)$totalDevEfectivo;

$colorBalanceRutas = $totalBalanceRutas >= 0
    ? 'text-green-600 dark:text-green-400'
    : 'text-red-600 dark:text-red-400';

// Labels y montos para gráfica (ventas por ruta)
$labelsRutasSemana = $rutasSemPorEmpleado->map(function ($ruta) {
    $base = $ruta->nombre_ruta ?? ('Ruta ' . ($ruta->ruta_id ?? ''));
    return trim(explode(' - ', $base)[0]);
})->values()->toArray();

$montosRutasSemana = $rutasSemPorEmpleado
    ->map(fn($ruta) => (float)($ruta->total_ventas_monto ?? 0))
    ->values()->toArray();

// Labels y montos para gráfica por día
$labelsRutasPorDia = $rutasPorDia
    ->map(fn($dia) => ucfirst(Carbon::parse($dia->fecha)->translatedFormat('D'))) // Jue, Vie, Sáb...
    ->values()->toArray();


$montosRutasPorDia = $rutasPorDia
    ->map(fn($dia) => (float)($dia->ventas_totales ?? 0))
    ->values()->toArray();

// =======================
// VENTAS INDIVIDUALES
// =======================
$ventasPorDia        = collect(data_get($datos, 'ventas_por_dia', []));
$montoTotalSemana    = (float)$ventasPorDia->sum('monto_total');
$gastosSemanaGeneral = (float) data_get($datos, 'gastos', 0);
$balanceVentas       = $montoTotalSemana - $gastosSemanaGeneral;

$colorBalanceVentas = $balanceVentas >= 0
    ? 'text-green-600 dark:text-green-400'
    : 'text-red-600 dark:text-red-400';

// Datos para gráfica semanal (ventas individuales por día)
$labelsVentasSemana = $ventasPorDia
    ->map(fn($dia) => Carbon::parse($dia->fecha_venta)->format('d/m'))
    ->values()->toArray();

$montosVentasSemana = $ventasPorDia
    ->map(fn($dia) => (float)$dia->monto_total)
    ->values()->toArray();

// =======================
// MODAL DATA (SEMANAL) ✅ igual que diario
// =======================
$gastosDetalleSemana     = collect(data_get($datos, 'gastos_detalle', []));
$gastosRutaDetalleSemana = collect(data_get($datos, 'gastos_ruta_detalle', []));
$gastosRutaTotalesSemana = collect(data_get($datos, 'gastos_ruta_totales', []));

$categoriaLabel = function ($c) {
    try { return \App\Models\Gasto::CATEGORIAS[$c] ?? ($c ?? '-'); } catch (\Throwable $e) { return $c ?? '-'; }
};
$metodoLabel = function ($m) {
    try { return \App\Models\Gasto::METODOS_PAGO[$m] ?? ($m ?? '-'); } catch (\Throwable $e) { return $m ?? '-'; }
};

$resumenCatGeneralesSemana = $gastosDetalleSemana->groupBy('categoria')
    ->map(fn($rows) => $rows->sum(fn($r) => (float)($r->monto ?? 0)))->sortDesc();

$resumenMetodoGeneralesSemana = $gastosDetalleSemana->groupBy('metodo_pago')
    ->map(fn($rows) => $rows->sum(fn($r) => (float)($r->monto ?? 0)))->sortDesc();

$resumenCatRutasSemana = $gastosRutaDetalleSemana->groupBy('categoria')
    ->map(fn($rows) => $rows->sum(fn($r) => (float)($r->monto ?? 0)))->sortDesc();

$resumenMetodoRutasSemana = $gastosRutaDetalleSemana->groupBy('metodo_pago')
    ->map(fn($rows) => $rows->sum(fn($r) => (float)($r->monto ?? 0)))->sortDesc();

// ✅ JSON GASTOS RUTA (para modal ruta_detalle)
$gastosRutaDetalleSemanaJson = $gastosRutaDetalleSemana->map(fn($g) => [
    'ruta_id'         => $g->ruta_id ?? null,
    'fecha'           => $g->fecha ?? null,
    'categoria'       => $g->categoria ?? null,
    'categoria_label' => $categoriaLabel($g->categoria ?? null),
    'descripcion'     => $g->descripcion ?? null,
    'monto'           => (float)($g->monto ?? 0),

    // opcionales (si tu query los trae, el modal arma mejor el título)
    'ruta_nombre'     => $g->ruta_nombre ?? null,
    'empleado'        => $g->empleado ?? null,
])->values()->all();

/**
 * ✅ CLAVE:
 * Convertimos el detalle de ventas al formato que tu JS ya usa.
 * Y soportamos distintas keys (por si tu controller semanal lo manda diferente).
 */
$ventasRutaDetalleSemanaJson = collect(
    data_get(
        $datos,
        'rutas_semanales.ventas_detalle',
        data_get($datos, 'rutas_movimientos_detalle', [])
    )
)->map(function ($v) {

    $ventasUnid = (int)($v->ventas ?? $v->ventas_unidades ?? 0);
    $devUnid    = (int)($v->devoluciones ?? $v->devoluciones_unidades ?? 0);

    $precioU = (float)($v->precio_unitario ?? $v->unit_price ?? $v->precio ?? 0);

    // si ya viene devoluciones_monto lo respetamos; si no, lo calculamos
    $devProdMonto = (float)($v->devoluciones_monto ?? ($devUnid * $precioU));

    // devolución efectivo
    $devEfecMonto = (float)(
        $v->devoluciones_efectivo_monto ??
        $v->devolucion_efectivo ??
        $v->devoluciones_efectivo ??
        0
    );

    // total devoluciones ($)
    $devTotMonto = (float)($v->devoluciones_total_monto ?? ($devProdMonto + $devEfecMonto));

    return [
        'ruta_id'     => $v->ruta_id ?? null,
        'fecha'       => $v->fecha ?? ($v->fecha_venta ?? null),
        'producto'    => $v->producto ?? ($v->nombre_producto ?? null),

        // opcionales para título
        'ruta_nombre' => $v->ruta_nombre ?? ($v->nombre_ruta ?? null),
        'empleado'    => $v->empleado ?? null,

        // ✅ para el JS (usa ventas/devoluciones)
        'ventas'       => $ventasUnid,
        'devoluciones' => $devUnid,

        // ✅ aliases por compatibilidad
        'ventas_unidades'       => $ventasUnid,
        'devoluciones_unidades' => $devUnid,

        'precio_unitario'    => $precioU,
        'devoluciones_monto' => $devProdMonto,

        'devoluciones_efectivo_monto' => $devEfecMonto,
        'devolucion_efectivo'         => $devEfecMonto, // alias

        'devoluciones_total_monto' => $devTotMonto,

        'total' => (float)($v->total ?? 0),
    ];
})
// ✅ FILTRO: solo filas con ventas o devoluciones (o devolución en efectivo)
->filter(fn($row) =>
    ((int)($row['ventas'] ?? 0) > 0) ||
    ((int)($row['devoluciones'] ?? 0) > 0) ||
    ((float)($row['devoluciones_efectivo_monto'] ?? 0) > 0)
)
->values()->all();

$gastosRutaTotalesSemanaJson = $gastosRutaTotalesSemana->map(fn($rt) => [
    'ruta_id'     => $rt->ruta_id ?? null,
    'ruta_nombre' => $rt->ruta_nombre ?? null,
    'empleado'    => $rt->empleado ?? null,
